www.blog-ctchen.com, blog-ctchen.com {
	root * /srv
	encode gzip zstd

	# Static export uses trailingSlash: path/ -> path/index.html
	try_files {path} {path}/index.html {path}.html

	# Long-cache hashed Next.js assets
	header /_next/static/* Cache-Control "public, max-age=31536000, immutable"

	file_server

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
